{
  "author": "Troy Forster <troy@tforster.com>",
  "bugs": {
    "url": "https://github.com/tforster/gilbert/issues"
  },
  "description": "Virtual file format for Gilbert",
  "devDependencies": {
    "mime-db": "^1.54.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "exports": {
    ".": "./lib/index.js"
  },
  "files": [
    "lib/",
    "README.md"
  ],
  "homepage": "https://github.com/tforster/gilbert#readme",
  "keywords": [
    "gilbert",
    "static-site-generator",
    "text-file-compiler",
    "web-api-streams",
    "virtual-file"
  ],
  "license": "MIT",
  "main": "lib/index.js",
  "name": "@tforster/gilbert-file",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "directory": "services/gilbert-file",
    "type": "git",
    "url": "git+ssh://git@github.com/tforster/gilbert.git"
  },
  "scripts": {
    "build": "node scripts/build.js",
    "docs": "jsdoc2md lib/**/*.js > API.md",
    "docs:advanced": "node scripts/generate-docs.js",
    "docs:watch": "nodemon --watch lib --ext js --exec \"npm run docs\"",
    "test": "node --test tests/**/*.test.js",
    "test:watch": "node --test --watch tests/**/*.test.js"
  },
  "type": "module",
  "version": "1.0.0-rc.4"
}