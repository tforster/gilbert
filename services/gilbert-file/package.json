{
  "author": "Troy Forster <troy.forster@gmail.com> (http://www.tforster.com/)",
  "dependencies": {},
  "description": "Virtual file format for Gilbert",
  "devDependencies": {
    "jsdoc": "^4.0.5",
    "jsdoc-to-markdown": "^9.1.3",
    "mime-db": "^1.54.0"
  },
  "exports": {
    ".": "./lib/index.js"
  },
  "files": [
    "lib/"
  ],
  "license": "MIT",
  "main": "lib/index.js",
  "name": "@tforster/gilbert-file",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/tforster/webproducer.git"
  },
  "scripts": {
    "build": "node scripts/build.js",
    "docs": "jsdoc2md lib/**/*.js > API.md",
    "docs:advanced": "node scripts/generate-docs.js",
    "docs:watch": "nodemon --watch lib --ext js --exec \"npm run docs\"",
    "test": "node --test tests/**/*.test.js",
    "test:watch": "node --test --watch tests/**/*.test.js"
  },
  "type": "module",
  "version": "0.1.0"
}
