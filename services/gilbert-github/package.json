  "main": "lib/index.js",
  "name": "@tforster/gilbert-github",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "directory": "services/gilbert-github",
    "type": "git",
    "url": "git+ssh://git@github.com/tforster/gilbert.git"
  },
  "scripts": {
    "test": "node --test tests/index.test.js --test-concurrency=1"
