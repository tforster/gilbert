    "README.md"
  ],
  "homepage": "https://github.com/tforster/gilbert#readme",
  "keywords": [
    "gilbert",
    "static-site-generator",
    "text-file-compiler",
    "web-api-streams",
    "github",
    "adapter"
  ],
