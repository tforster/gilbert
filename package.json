{
  "name": "@tforster/gilbert-monorepo",
  "version": "1.0.0-rc.3",
  "private": true,
  "description": "Workspace container for the Gilbert and GilbertFile modules.",
  "homepage": "https://github.com/tforster/gilbert#readme",
  "bugs": {
    "url": "https://github.com/tforster/gilbert/issues"
  },
  "license": "MIT",
  "author": "Troy Forster <troy.forster@gmail.com> (https://www.tforster.com)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tforster/gilbert.git"
  },
  "funding": {
    "type": "patreon",
    "url": "https://www.patreon.com/tforster"
  },
  "workspaces": [
    "services/gilbert-cli",
    "services/gilbert-file",
    "services/gilbert",
    "services/gilbert-fs",
    "services/gilbert-github",
    "services/gilbert-glob",
    "services/gilbert-logger",
    "services/gilbert-r2"
  ],
  "type": "module",
  "scripts": {
    "build:gilbert-file": "npm run build -w services/gilbert-file",
    "docs": "jsdoc -c jsdoc.config.json",
    "docs:clean": "rm -rf docs/api",
    "docs:serve": "npx http-server docs/api -p 8080",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "test": "node devops/test.js",
    "test:all": "npm run test && npm run test:performance",
    "test:performance": "node --test tests/performance/performance.test.js"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260405.1",
    "@eslint/compat": "^2.0.4",
    "@eslint/js": "^10.0.1",
    "@eslint/json": "^1.2.0",
    "@eslint/markdown": "^8.0.1",
    "@html-eslint/eslint-plugin": "^0.59.0",
    "@html-eslint/parser": "^0.59.0",
    "@types/node": "^25.5.2",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsonc": "^3.1.2",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-yml": "^3.3.1",
    "globals": "^17.4.0",
    "jsdoc": "^4.0.5",
    "oxfmt": "^0.43.0",
    "oxlint": "^1.58.0",
    "prettier": "^3.8.1",
    "yaml-eslint-parser": "^2.0.0"
  },
  "overrides": {
    "eslint": "^10.2.0",
    "glob-parent": "5.1.2",
    "lodash": "4.17.21"
  }
}
