  },
  "description": "Workspace container for the Gilbert and GilbertFile modules.",
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20251115.0",
    "@eslint/compat": "^1.3.2",
    "@eslint/js": "^9.35.0",
    "@eslint/json": "^0.13.2",
    "@eslint/markdown": "^7.2.0",
    "@html-eslint/eslint-plugin": "^0.46.2",
    "@html-eslint/parser": "^0.46.2",
    "@types/node": "^24.3.1",
    "eslint": "^9.35.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsonc": "^2.20.1",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-yml": "^1.18.0",
    "globals": "^16.4.0",
    "jsdoc": "^4.0.4",
    "prettier": "^3.6.2",
    "yaml-eslint-parser": "^1.3.0"
  },
  "overrides": {
    "glob-parent": "5.1.2",
    "lodash": "4.17.21"
  },
  "funding": {
    "type": "patreon",
    "url": "https://www.patreon.com/tforster"
  },
  "homepage": "https://github.com/tforster/webproducer#readme",
  "license": "MIT",
  "name": "@tforster/webproducer-monorepo",
  "private": true,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tforster/webproducer.git"
  },
  "scripts": {
    "build:gilbert-file": "npm run build -w services/gilbert-file",
    "docs": "jsdoc -c jsdoc.config.json",
    "docs:clean": "rm -rf docs/api",
    "docs:serve": "npx http-server docs/api -p 8080",
    "test": "npm run test --workspaces --if-present",
    "test:all": "node --test tests/index.test.js --test-concurrency=1",
    "test:performance": "node --test tests/performance/performance.test.js"
  },
  "type": "module",
  "version": "1.0.0-beta.5",
  "workspaces": [
    "services/gilbert-cli",
    "services/gilbert-file",
    "services/gilbert",
    "services/gilbert-fs",
    "services/gilbert-github",
    "services/gilbert-glob",
    "services/gilbert-logger",
    "services/gilbert-r2"
  ]
}
