{
  "name": "@tforster/gilbert-monorepo",
  "version": "1.0.0-rc.1",
  "private": true,
  "description": "Workspace container for the Gilbert and GilbertFile modules.",
  "homepage": "https://github.com/tforster/webproducer#readme",
  "bugs": {
    "url": "https://github.com/tforster/webproducer/issues"
  },
  "license": "MIT",
  "author": "Troy Forster <troy.forster@gmail.com> (https://www.tforster.com)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tforster/webproducer.git"
  },
  "funding": {
    "type": "patreon",
    "url": "https://www.patreon.com/tforster"
  },
  "workspaces": [
    "services/gilbert-cli",
    "services/gilbert-file",
    "services/gilbert",
    "services/gilbert-fs",
    "services/gilbert-github",
    "services/gilbert-glob",
    "services/gilbert-logger",
    "services/gilbert-r2"
  ],
  "type": "module",
  "scripts": {
    "build:gilbert-file": "npm run build -w services/gilbert-file",
    "docs": "jsdoc -c jsdoc.config.json",
    "docs:clean": "rm -rf docs/api",
    "docs:serve": "npx http-server docs/api -p 8080",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "test": "npm run test --workspaces --if-present --workspace-concurrency=1",
    "test:all": "npm run test && npm run test:performance",
    "test:performance": "node --test tests/performance/performance.test.js"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20251205.0",
    "@eslint/compat": "^2.0.0",
    "@eslint/js": "^9.39.1",
    "@eslint/json": "^0.14.0",
    "@eslint/markdown": "^7.5.1",
    "@html-eslint/eslint-plugin": "^0.50.0",
    "@html-eslint/parser": "^0.50.0",
    "@types/node": "^24.10.1",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsonc": "^2.21.0",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-yml": "^1.19.0",
    "globals": "^16.5.0",
    "jsdoc": "^4.0.5",
    "oxfmt": "^0.43.0",
    "oxlint": "^1.58.0",
    "prettier": "^3.7.4",
    "yaml-eslint-parser": "^1.3.2"
  },
  "overrides": {
    "glob-parent": "5.1.2",
    "lodash": "4.17.21"
  }
}
