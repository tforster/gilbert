<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{title}}</title>
</head>
<body>
    <h1>{{title}}</h1>
    <p>{{description}}</p>
    <div class="content">
        {{#if content}}
            {{{content}}}
        {{else}}
            <p>No content available.</p>
        {{/if}}
    </div>
    <footer>
        <p>Generated on {{generatedAt}}</p>
    </footer>
</body>
</html>